# ============================================================
# HotelScope — 環境変数テンプレート
# このファイルをコピーして .env.local を作成し、各値を設定してください
# cp .env.local.example .env.local
# ============================================================

# NextAuth（必須）— openssl rand -base64 32 で生成
NEXTAUTH_SECRET=

# 管理者アカウント（必須）
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Gemini AI（管理者用）— https://aistudio.google.com/app/apikey
ADMIN_GEMINI_KEY=

# 楽天トラベル API — https://webservice.rakuten.co.jp/
RAKUTEN_APP_ID=

# データベース（本番用 Neon PostgreSQL）— 未設定時はローカルJSON
DATABASE_URL=

# Cron ジョブ保護 — openssl rand -hex 32 で生成
CRON_SECRET=

# モックデータ表示（開発時のみ true）
# NEXT_PUBLIC_ENABLE_MOCK=true
